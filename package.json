{
  "name": "unicode-eingabe-kiwi3",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "build": "vue-tsc --build --noCheck && vite build && npm run copy-locales",
    "copy-locales": "mkdir -p dist/locales && cp -r src/locales/* dist/locales/",
    "generate:din-locales": "python3 scripts/generate-din-locale-files.py",
    "lint": "prettier src/ tests/ --check && eslint . && vue-tsc --noEmit",
    "format": "prettier src/ tests/ --write",
    "fix": "prettier . --write && eslint . --fix"
  },
  "dependencies": {
    "@fontsource/roboto": "5.2.10",
    "@types/webfontloader": "1.6.38",
    "@vueuse/core": "14.3.0",
    "graphemer": "1.4.0",
    "pinia": "3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "vue": "3.5.35",
    "vue-i18n": "11.4.5",
    "vue-router": "5.1.0",
    "vuetify": "4.0.8",
    "webfontloader": "1.6.28"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@mdi/js": "7.4.47",
    "@muenchen/prettier-codeformat": "1.0.2",
    "@tsconfig/node-lts": "24.0.0",
    "@types/node": "25.9.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.10",
    "@vue/tsconfig": "0.9.1",
    "esbuild": "0.28.0",
    "eslint": "10.4.1",
    "eslint-plugin-vue": "10.9.1",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "unplugin-fonts": "2.0.0",
    "vite": "8.0.16",
    "vite-plugin-vue-devtools": "8.1.2",
    "vite-plugin-vuetify": "2.1.3",
    "vitest": "4.1.8",
    "vue-tsc": "3.3.3"
  }
}
